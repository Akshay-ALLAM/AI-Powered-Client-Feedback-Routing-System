    {
      "parameters": {
        "jsCode": "const labels = ['Name', 'Email', 'Rating', 'Sentiment', 'Priority', 'Problem', 'Solution', 'Risk Level'];\n\nfunction getValue(text, label) {\n  const otherLabels = labels.filter(l => l !== label).join('|');\n  const regex = new RegExp(`${label}:\\\\s*([\\\\s\\\\S]*?)(?=\\\\n(?:${otherLabels}):|$)`, 'i');\n  return text.match(regex)?.[1]?.trim() || '';\n}\n\nreturn $input.all().map(item => {\n  const text = item.json.output || '';\n\n  return {\n    json: {\n      Name: getValue(text, 'Name'),\n      Email: getValue(text, 'Email'),\n      Rating: getValue(text, 'Rating'),\n      Sentiment: getValue(text, 'Sentiment'),\n      Priority: getValue(text, 'Priority'),\n      Problem: getValue(text, 'Problem'),\n      Solution: getValue(text, 'Solution'),\n      'Risk Level': getValue(text, 'Risk Level'),\n    },\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
